<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ══ الثيم الفاتح (values/ الافتراضي) ══
         نفس أسماء الألوان بالظبط الموجودة في values-night/colors.xml — بس بقيم فاتحة.
         الفكرة إن كل layout في المشروع بيستخدم @color/background_dark أو @color/text_primary
         بالاسم، فمش محتاجين نلمس ولا XML واحد تاني؛ AppCompatDelegate.setDefaultNightMode
         (شوف AppDisplayMode.kt) هو اللي بيقرر أي نسخة من الملفين تتفعل. -->
    <color name="background_dark">#F1F2F5</color>
    <!-- سطح البطاقات في الوضع الفاتح — أبيض صريح عشان يفضل فيه تمايز واضح عن خلفية الصفحة -->
    <color name="surface_dark">#FFFFFF</color>
    <color name="accent_orange">#FF8A1E</color>
    <color name="accent_blue">#1A6FD1</color>
    <color name="text_primary">#15171C</color>
    <color name="text_secondary">#5B6472</color>
    <color name="warning_red">#D93A2E</color>
    <color name="success_green">#1F8F58</color>
</resources>
